# Database
POSTGRES_USER=chatia_user
POSTGRES_PASSWORD=change_this_password
POSTGRES_DB=chatia_db
DATABASE_URL=postgresql://chatia_user:change_this_password@db:5432/chatia_db

# Redis
REDIS_URL=redis://redis:6379/0

# Security
JWT_SECRET_KEY=your_secret_key_here
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15

# LLM
OPENAI_API_KEY=sk-...
GROQ_API_KEY=gsk_...
HUGGINGFACE_TOKEN=hf_...
DEFAULT_LLM_MODEL=llama-3-70b-8192

# Embeddings
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIMENSION=384

# MemoRAG
MEMORAG_THRESHOLD_TOKENS=20000
MEMORAG_ENABLED=true

# File Upload
MAX_FILE_SIZE_MB=50
ALLOWED_EXTENSIONS=pdf

# Cloudflare
CLOUDFLARE_TUNNEL_TOKEN=your_tunnel_token
CLOUDFLARE_DOMAIN=your-domain.com

# App
ENVIRONMENT=production
DEBUG=false
LOG_LEVEL=INFO
